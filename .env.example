PORT=4001
NODE_ENV=development
FRONTEND_URL=http://localhost:4000
EMAIL_URL=http://localhost:4000
MONGODB_URI=mongodb://localhost:27017/aiadscreator
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-gmail-app-password
MAIL_FROM=AI Ad Creator <your-email@gmail.com>
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# When true, the AI suggestion prompt is grounded in the user's past Meta
# campaigns (last 90 days, ranked by CTR/spend) pulled live from Graph API.
# Set to "false" to disable and fall back to AI-from-brand-context only.
META_HISTORY_SUGGESTIONS_ENABLED=true

# --- Google Ads (Performance Max) ---
# Apply for Basic access at ads.google.com/home/tools/manager-accounts/ → API Center.
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
# OAuth 2.0 client (Web application) from GCP Credentials.
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# Must exactly match an Authorized redirect URI in the GCP OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4001/google-ads/oauth/callback
# Your MCC (Manager) customer ID, digits only (no dashes). Optional — required
# only when managing client accounts through an MCC.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Seed Admin (used by npm run seed:admin)
ADMIN_EMAIL=admin@aiadscreator.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
