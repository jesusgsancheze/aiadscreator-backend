PORT=4001
NODE_ENV=development
# Comma-separated list of allowed origins (e.g. "https://app.example.com,https://www.example.com").
FRONTEND_URL=http://localhost:4000
# Base URL used to build links inside emails. Falls back to FRONTEND_URL if unset.
EMAIL_URL=http://localhost:4000
MONGODB_URI=mongodb://localhost:27017/aiadscreator
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# --- Email (Resend) ---
# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
# Must use a verified sender domain in Resend. For quick tests you can use
# "onboarding@resend.dev" — that's Resend's shared test sender.
MAIL_FROM=AI Ad Creator <no-reply@example.com>

# --- Cloudflare R2 (S3-compatible object storage for user uploads) ---
# Your Cloudflare account ID (used to build the R2 endpoint URL).
R2_ACCOUNT_ID=your-cloudflare-account-id
# R2 API token: Access Key ID + Secret (create in R2 → Manage R2 API Tokens).
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Bucket name (lowercase, no spaces).
R2_BUCKET=aiadscreator-uploads
# Public base URL of the bucket. Either the R2.dev dev subdomain (for testing)
# or a custom domain connected to the bucket (recommended for prod).
# Examples: "https://pub-xxxxxxxxxxxxxxxxxxxxxxxx.r2.dev" or "https://cdn.example.com".
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
# Optional key prefix applied to every uploaded object. Defaults to "uploads".
R2_KEY_PREFIX=uploads

# --- AI providers ---
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# When true, the AI suggestion prompt is grounded in the user's past Meta
# campaigns (last 90 days, ranked by CTR/spend) pulled live from Graph API.
# Set to "false" to disable and fall back to AI-from-brand-context only.
META_HISTORY_SUGGESTIONS_ENABLED=true

# --- Google Ads (Performance Max) ---
# Apply for Basic access at ads.google.com/home/tools/manager-accounts/ → API Center.
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
# OAuth 2.0 client (Web application) from GCP Credentials.
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# Must exactly match an Authorized redirect URI in the GCP OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4001/google-ads/oauth/callback
# Your MCC (Manager) customer ID, digits only (no dashes). Optional — required
# only when managing client accounts through an MCC.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

MAX_FILE_SIZE=10485760

# Seed Admin (used by npm run seed:admin)
ADMIN_EMAIL=admin@aiadscreator.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
